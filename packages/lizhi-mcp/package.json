{
  "name": "@lizhi/mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "狸知知识库 MCP stdio 服务（HTTP Bridge）",
  "bin": {
    "lizhi-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --banner:js=\"#!/usr/bin/env node\"",
    "start": "node dist/index.js",
    "dev": "pnpm build && node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "esbuild": "^0.25.5",
    "typescript": "~5.6.2"
  }
}
